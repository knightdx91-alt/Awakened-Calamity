  {
   "id": 25,
   "name": "ReplaySeedBoard",
   "x": 32,
   "y": 34,
   "graphic": {
    "sprite": "NoticeBoard",
    "file": "rtp/NoticeBoard.png",
    "frame_w": 32,
    "frame_h": 32,
    "cols": 3,
    "rows": 4,
    "single": false
   },
   "dir": "down",
   "trigger": "action",
   "through": false,
   "commands": [
    {
     "type": "text",
     "text": "THE REPLAY SLATE \u2014 the System pins the SHAPE of a descent here. The same seed grows the same floors and relic caches.\nLast descent's seed: [v:run_seed]\nPinned for next descent: [v:run_seed_in]  (0 = fresh, random)\nPinned shape:  [actforecast]"
    },
    {
     "type": "choice",
     "prompt": "Set the seed for your next descent?",
