   "trigger": "action",
   "through": false,
   "commands": [
    {
     "type": "text",
     "text": "\u2756 THE FRACTURE \u2014 the way DOWN \u2756\nA fracture in the air hums where the System thins \u2014 a way DOWN, into the dark beneath Dawnhearth."
    },
    {
     "type": "text",
     "text": "DESCENT FORECAST:  [actforecast]\n\u2694 fight  \u2605 elite  \u2726 treasure  \u263e refuge  \ud835\udd6d Alpha"
    },
    {
     "type": "choice",
     "prompt": "How will you descend?",
     "options": [
      {
       "label": "Tethered",
       "then": [
        {
         "type": "text",
         "text": "You keep the System close. It will not let you die down there \u2014 and it will never stop watching. (Surveillance climbs toward Collection.)"
        },
        {
         "type": "run",
         "op": "start",
         "tethered": true
        },
        {
         "type": "gendungeon"
        }
       ]
      },
      {
       "label": "Untethered",
       "then": [
        {
         "type": "text",
         "text": "You cut the tether. No hand will catch you \u2014 death is real. But the System loses its grip, and you stay yourself. (The off-grid path.)"
        },
        {
         "type": "run",
         "op": "start",
         "tethered": false
        },
        {
         "type": "gendungeon"
        }
       ]
      },
      {
       "label": "Not yet",
       "then": [
        {
         "type": "text",
         "text": "You step back. The fracture waits."
        }
       ]
      }
     ]
    }
   ]
  },
  {
