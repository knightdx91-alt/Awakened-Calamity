{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chrome/**",
              "components/hub/**",
              "components/meters/**",
              "components/system/**",
              "components/world/**",
              "ui_kits/game/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Press Start 2P))/i]",
        "message": "Font not provided by the design system. Available: Press Start 2P."
      },
      {
        "selector": "JSXOpeningElement[name.name='AffinityBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:affinity|label|size|key|ref|className|style|children)$/]",
        "message": "<AffinityBadge> doesn't accept that prop. Declared props: affinity, label, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='AffinityBadge'] > JSXAttribute[name.name='affinity'] > Literal[value!=/^(?:ember|tide|verdant|storm|stone|frost|toxin|umbral|lumen|corruption|untethered)$/]",
        "message": "<AffinityBadge> affinity must be one of 'ember' | 'tide' | 'verdant' | 'storm' | 'stone' | 'frost' | 'toxin' | 'umbral' | 'lumen' | 'corruption' | 'untethered'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AffinityBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<AffinityBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DialogueBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|speaker|showArrow|key|ref|className|style|children)$/]",
        "message": "<DialogueBox> doesn't accept that prop. Declared props: text, speaker, showArrow."
      },
      {
        "selector": "JSXOpeningElement[name.name='FrButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|disabled|size|children|key|ref|className|style|children)$/]",
        "message": "<FrButton> doesn't accept that prop. Declared props: active, disabled, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FrButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<FrButton> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FrWindow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|variant|shadow|bodyStyle|children|key|ref|className|style|children)$/]",
        "message": "<FrWindow> doesn't accept that prop. Declared props: title, variant, shadow, bodyStyle, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FrWindow'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:body|light)$/]",
        "message": "<FrWindow> variant must be one of 'body' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FrWindow'] > JSXAttribute[name.name='shadow'] > Literal[value!=/^(?:sm|lg|none)$/]",
        "message": "<FrWindow> shadow must be one of 'sm' | 'lg' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HazardChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:hazard|showLabel|size|key|ref|className|style|children)$/]",
        "message": "<HazardChip> doesn't accept that prop. Declared props: hazard, showLabel, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='HazardChip'] > JSXAttribute[name.name='hazard'] > Literal[value!=/^(?:heat|cold|toxic|gloom|tempest)$/]",
        "message": "<HazardChip> hazard must be one of 'heat' | 'cold' | 'toxic' | 'gloom' | 'tempest'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HazardChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<HazardChip> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LaunchCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|icon|href|key|ref|className|style|children)$/]",
        "message": "<LaunchCard> doesn't accept that prop. Declared props: title, subtitle, icon, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapMarker'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|hazard|label|size|key|ref|className|style|children)$/]",
        "message": "<MapMarker> doesn't accept that prop. Declared props: type, hazard, label, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapMarker'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:safe|hold|route|dungeon|calamity|hidden|water|under)$/]",
        "message": "<MapMarker> type must be one of 'safe' | 'hold' | 'route' | 'dungeon' | 'calamity' | 'hidden' | 'water' | 'under'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapMarker'] > JSXAttribute[name.name='hazard'] > Literal[value!=/^(?:heat|cold|toxic|gloom|tempest)$/]",
        "message": "<MapMarker> hazard must be one of 'heat' | 'cold' | 'toxic' | 'gloom' | 'tempest'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|selected|cursor|right|key|ref|className|style|children)$/]",
        "message": "<MenuRow> doesn't accept that prop. Declared props: label, selected, cursor, right."
      },
      {
        "selector": "JSXOpeningElement[name.name='MeterBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|color|showText|width|key|ref|className|style|children)$/]",
        "message": "<MeterBar> doesn't accept that prop. Declared props: value, max, label, color, showText, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='SurveillanceMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|width|key|ref|className|style|children)$/]",
        "message": "<SurveillanceMeter> doesn't accept that prop. Declared props: value, max, label, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='SystemNotify'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|message|children|key|ref|className|style|children)$/]",
        "message": "<SystemNotify> doesn't accept that prop. Declared props: type, label, message, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SystemNotify'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:info|warning|danger)$/]",
        "message": "<SystemNotify> type must be one of 'info' | 'warning' | 'danger'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
